      </collision>
      <collision>
        <origin xyz="0.0 0.0 0.02" rpy="1.5708 0.0 0.0"/>
        <geometry>
          <cylinder radius="0.05" length="0.14"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}arm_joint2" type="revolute">
      <origin xyz="-0.0 0.068 0.033" rpy="0 1.570796 0"/>
      <parent link="${prefix}link1_1"/>
      <child link="${prefix}link2_1"/>
      <axis xyz="0.0 1.0 -0.0"/>
      <limit upper="1.658063" lower="-1.570796" effort="100" velocity="100"/>
    </joint>

    <!-- joint3 -->
    <link name="${prefix}link2_1">
      <inertial>
        <origin xyz="-0.3593097621686804 -0.06810779615005684 0.016735508519571035" rpy="0 0 0"/>
        <mass value="1.527495790136376"/>
        <inertia ixx="0.003876" iyy="0.025758" izz="0.028443" ixy="-8e-06" iyz="-3e-06" ixz="0.001945"/>
      </inertial>
      <visual>
        <origin xyz="0.0 -0.068 -0.171" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/link2_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver">

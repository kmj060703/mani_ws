        <inertia ixx="0.000529" iyy="0.000264" izz="0.000688" ixy="5.7e-05" iyz="0.0" ixz="-0.0"/>
      </inertial>
      <visual>
        <origin xyz="0.115484 1e-06 -0.225028" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/link4_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver">

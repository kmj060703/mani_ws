      <collision>
        <origin xyz="-0.218 -0.02 -0.003" rpy="0.0 1.5708 0.0"/>
        <geometry>
          <cylinder radius="0.035" length="0.436"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.218 -0.07 -0.003" rpy="0.0 1.5708 0.0"/>
        <geometry>
          <cylinder radius="0.035" length="0.436"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="-0.218 -0.12 -0.003" rpy="0.0 1.5708 0.0"/>
        <geometry>
          <cylinder radius="0.035" length="0.436"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}arm_joint3" type="revolute">
      <origin xyz="-0.436012 -3e-06 0.026857" rpy="0 3.141593 0"/>
      <parent link="${prefix}link2_1"/>
      <child link="${prefix}link3_1"/>
      <axis xyz="0.0 1.0 0.0"/>
      <limit upper="3.141593" lower="0.0" effort="100" velocity="100"/>
    </joint>

    <!-- joint4 -->
    <link name="${prefix}link3_1">
      <inertial>
        <origin xyz="0.18345019759983328 -0.06799908234450751 0.0261367861497811" rpy="0 0 0"/>
        <mass value="0.9709547878732533"/>
        <inertia ixx="0.001321" iyy="0.011522" izz="0.012245" ixy="-0.0" iyz="-0.0" ixz="-0.000184"/>
      </inertial>
      <visual>
        <origin xyz="0.436012 -0.067997 -0.197857" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/link3_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver">
          <color rgba="0.700 0.700 0.700 1.000"/>

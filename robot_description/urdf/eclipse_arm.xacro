<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="eclipse_arm" params="prefix">
    <xacro:property name="meshes_path" value="package://robot_description/meshes/eclipse_arm"/>

    <!-- joint1 -->
    <link name="${prefix}mani_base_link">
      <inertial>
        <origin xyz="4.1218556887289874e-07 7.067628412789034e-06 0.07667542797449876" rpy="0 0 0"/>
        <mass value="1.1862415046241324"/>
        <inertia ixx="0.002538" iyy="0.002537" izz="0.000822" ixy="-0.0" iyz="-0.0" ixz="-0.0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/mani_base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver">
          <color rgba="0.700 0.700 0.700 1.000"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/mani_base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="0.0 0.0 0.07" rpy="0.0 0.0 0.0"/>
        <geometry>
          <cylinder radius="0.07" length="0.14"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}arm_joint1" type="revolute">
      <origin xyz="0.0 0.0 0.138" rpy="0 0 0"/>
      <parent link="${prefix}mani_base_link"/>
      <child link="${prefix}link1_1"/>
      <axis xyz="0.0 0.0 1.0"/>
      <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
    </joint>

    <!-- joint2 -->
    <link name="${prefix}link1_1">
      <inertial>
        <origin xyz="6.45978317664672e-07 -0.0001609789621932034 0.029682954180736465" rpy="0 0 0"/>
        <mass value="1.0875137678049913"/>
        <inertia ixx="0.001819" iyy="0.000579" izz="0.001773" ixy="0.0" iyz="-1e-06" ixz="-0.0"/>
      </inertial>
      <visual>
        <origin xyz="-0.0 0.0 -0.138" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/link1_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver">
          <color rgba="0.700 0.700 0.700 1.000"/>
        </material>
      </visual>
      <collision>
        <origin xyz="-0.0 0.0 -0.138" rpy="0 0 0"/>

    <joint name="${prefix}arm_joint5" type="revolute">
      <origin xyz="0.0602 -0.027 0.0" rpy="0 0 0"/>
      <parent link="${prefix}link4_1"/>
      <child link="${prefix}link5_1"/>
      <axis xyz="0.0 1.0 0.0"/>
      <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
    </joint>

    <!-- before joint6 -->
    <link name="${prefix}link5_1">
      <inertial>
        <origin xyz="0.012837492850813946 0.027000310454766936 -1.1964334410696775e-05" rpy="0 0 0"/>
        <mass value="0.3671682127464688"/>
        <inertia ixx="0.00013" iyy="0.000195" izz="0.000218" ixy="-0.0" iyz="-0.0" ixz="-0.0"/>
      </inertial>
      <visual>
        <origin xyz="0.055284 0.027001 -0.225028" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/link5_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="silver">
          <color rgba="0.700 0.700 0.700 1.000"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0.055284 0.027001 -0.225028" rpy="0 0 0"/>
        <geometry>
          <mesh filename="${meshes_path}/link5_1.stl" scale="0.001 0.001 0.001"/>

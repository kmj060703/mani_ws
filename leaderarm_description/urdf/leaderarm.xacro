    </geometry>
  </collision>
</link>

<joint name="leader_rotation1" type="revolute">
  <origin xyz="-0.0145 0.0145 0.062" rpy="0 0 0"/>
  <parent link="leader_base_link"/>
  <child link="link_1_leader_1"/>
  <axis xyz="-0.0 0.0 1.0"/>
  <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
</joint>

<joint name="leader_rotation2" type="revolute">
  <origin xyz="0.0 0.026 0.0567" rpy="0 0 0"/>
  <parent link="link_1_leader_1"/>
  <child link="link_2_leader_1"/>
  <axis xyz="0.0 1.0 -0.0"/>
  <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
</joint>

<joint name="leader_rotation3" type="revolute">
  <origin xyz="-4e-06 -1e-05 0.3" rpy="0 0 0"/>
  <parent link="link_2_leader_1"/>
  <child link="link_3_leader_1"/>
  <axis xyz="-0.0 1.0 -0.0"/>
  <limit upper="3.141593" lower="0.0" effort="100" velocity="100"/>
</joint>

<joint name="leader_rotation4" type="revolute">
  <origin xyz="-0.039002 -0.02642 0.2765" rpy="0 0 0"/>
  <parent link="link_3_leader_1"/>
  <child link="link_4_leader_1"/>
  <axis xyz="-1.2e-05 0.0 1.0"/>
  <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
</joint>

<joint name="leader_rotation5" type="revolute">
  <origin xyz="0.0 0.0236 0.0533" rpy="0 0 0"/>
  <parent link="link_4_leader_1"/>
  <child link="link_5_leader_1"/>
  <axis xyz="0.0 1.0 -0.0"/>
  <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
</joint>

<joint name="leader_rotation6" type="revolute">
  <origin xyz="-1e-06 -0.02351 0.0705" rpy="0 0 0"/>
  <parent link="link_5_leader_1"/>
  <child link="gripper_leader_1"/>
  <axis xyz="-1.2e-05 0.0 1.0"/>
  <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
</joint>

<joint name="leader_rotation7" type="revolute">
  <origin xyz="-1e-06 -0.02075 0.0456" rpy="0 0 0"/>
  <parent link="gripper_leader_1"/>
  <child link="trigger_leader_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit upper="0.0" lower="-1.570796" effort="100" velocity="100"/>
</joint>

<ros2_control name="LeaderHardware" type="system">
    <hardware>
      <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>
      <param name="port_name">/dev/USBleader</param>
      <param name="baud_rate">1000000</param>
      <param name="dynamixel_model_folder">/param/dxl_model/</param>
      <param name="number_of_joints">7</param> 
      <param name="number_of_transmissions">7</param>
      <param name="loop_rate">100</param>
      <param name="use_fast_read">false</param>            <param name="use_indirect_address">true</param>
      <param name="error_timeout_ms">4000</param>
      <param name="disable_torque_at_init">false</param>
      <param name="torque_enable">true</param>
    </hardware>
    
    <joint name="leader_rotation1"><param name="id">1</param><param name="torque_enable">true</param><command_interface name="position"/><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="leader_rotation2"><param name="id">2</param><param name="torque_enable">true</param><command_interface name="position"/><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="leader_rotation3"><param name="id">3</param><param name="torque_enable">true</param><command_interface name="position"/><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="leader_rotation4"><param name="id">4</param><param name="torque_enable">true</param><command_interface name="position"/><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="leader_rotation5"><param name="id">5</param><param name="torque_enable">true</param><command_interface name="position"/><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="leader_rotation6"><param name="id">6</param><param name="torque_enable">true</param><command_interface name="position"/><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>
    <joint name="leader_rotation7"><param name="id">7</param><param name="torque_enable">true</param><command_interface name="position"/><command_interface name="effort"/><state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/></joint>

    <gpio name="dxl1">
      <param name="type">dxl</param><param name="ID">1</param>
      <param name="Operating Mode">0</param>
      <param name="Return Delay Time">10</param>
      <param name="Torque Enable">1</param>
      <command_interface name="Goal Current"/><state_interface name="Present Position"/>
    </gpio>
    <gpio name="dxl2">
      <param name="type">dxl</param><param name="ID">2</param>
      <param name="Operating Mode">0</param>
      <param name="Return Delay Time">10</param>
      <param name="Torque Enable">1</param>
      <command_interface name="Goal Current"/><state_interface name="Present Position"/>
    </gpio>
    <gpio name="dxl3">
      <param name="type">dxl</param><param name="ID">3</param>
      <param name="Operating Mode">0</param>
      <param name="Return Delay Time">10</param>
      <param name="Torque Enable">1</param>
      <command_interface name="Goal Current"/><state_interface name="Present Position"/>
    </gpio>
    <gpio name="dxl4">
      <param name="type">dxl</param><param name="ID">4</param>
      <param name="Operating Mode">0</param>
      <param name="Return Delay Time">10</param>
      <param name="Torque Enable">1</param>
      <command_interface name="Goal Current"/><state_interface name="Present Position"/>
    </gpio>
    <gpio name="dxl5">
      <param name="type">dxl</param><param name="ID">5</param>
      <param name="Operating Mode">0</param>
      <param name="Return Delay Time">10</param>
      <param name="Torque Enable">1</param>
      <command_interface name="Goal Current"/><state_interface name="Present Position"/>
    </gpio>
    <gpio name="dxl6">
      <param name="type">dxl</param><param name="ID">6</param>
      <param name="Operating Mode">0</param>
      <param name="Return Delay Time">10</param>
      <param name="Torque Enable">1</param>
      <command_interface name="Goal Current"/><state_interface name="Present Position"/>
    </gpio>
    <gpio name="dxl7">
      <param name="type">dxl</param><param name="ID">7</param>
      <param name="Operating Mode">16</param>
      <param name="Return Delay Time">10</param>
      <param name="Torque Enable">1</param>
      <command_interface name="Goal PWM"/><state_interface name="Present Position"/>
    </gpio>
  </ros2_control>

</robot>

<?xml version="1.0" ?>
<robot name="leaderarm" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find leaderarm_description)/urdf/materials.xacro" />
<xacro:include filename="$(find leaderarm_description)/urdf/leaderarm.trans" />
<xacro:include filename="$(find leaderarm_description)/urdf/leaderarm.gazebo" />
<link name="leader_base_link">
  <inertial>
    <origin xyz="-0.065404 -1e-6 -0.032733" rpy="0 0 0"/>
    <mass value="0.376"/>
    <inertia ixx="0.000629062" iyy="0.001478624" izz="0.001603261" ixy="0.00000003" iyz="0.0" ixz="0.000062369"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find leaderarm_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find leaderarm_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

